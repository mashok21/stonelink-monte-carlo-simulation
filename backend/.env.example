# ── Django core ─────────────────────────────────────────────────────────────
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-at-least-50-chars

# Comma-separated list of allowed hostnames (no scheme, no trailing slash)
# Include your Railway public domain once generated, e.g.:
#   your-service.up.railway.app,localhost,127.0.0.1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── CORS ─────────────────────────────────────────────────────────────────────
# Full origin URLs (with scheme) that the browser frontend is served from
DJANGO_CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173
DJANGO_CORS_ALLOWED_ORIGIN_REGEXES=^https://.*\.vercel\.app$

# ── CSRF ─────────────────────────────────────────────────────────────────────
# Full origin URLs trusted for CSRF. Must include your Railway domain.
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app,https://your-service.up.railway.app

# ── Throttling (requests per minute) ─────────────────────────────────────────
DRF_ANON_THROTTLE_RATE=120/min
DRF_USER_THROTTLE_RATE=600/min
SIMULATION_THROTTLE_RATE=20/min

# ── Security ─────────────────────────────────────────────────────────────────
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_HSTS_SECONDS=31536000

# ── Simulation behaviour ─────────────────────────────────────────────────────
SIMULATION_RUN_AUDIT_INLINE=false
# Log path override (Railway/Vercel default to /tmp automatically)
# SIMULATION_AUDIT_LOG_PATH=/tmp/simulation_audit.log

# ── Database (SQLite path; unused by simulation but required by Django) ───────
DJANGO_SQLITE_PATH=/tmp/db.sqlite3

# ── Observability ─────────────────────────────────────────────────────────────
DJANGO_LOG_LEVEL=INFO
OBSERVABILITY_ENABLED=true
ERROR_TRACKING_DSN=

# ── Version metadata (set by CI/CD, not secrets) ─────────────────────────────
# GIT_COMMIT=<commit-sha>
# GIT_COMMIT_DATE=<iso-date>
